<?xml version="1.0" encoding="windows-1252" ?>
<adfc-config xmlns="http://xmlns.oracle.com/adf/controller" version="1.2">
  <task-flow-definition id="siteTF">
    <default-activity>site</default-activity>
    <data-control-scope>
      <shared/>
    </data-control-scope>
    <!-- ? ADD THIS HERE to get the studyId -->
    <input-parameter-definition>
      <name>studyIdTF</name>
      <value>#{pageFlowScope.studyIdTF}</value>
    </input-parameter-definition>

    <view id="site">
      <page>/site.jsff</page>
    </view>
    <task-flow-return id="taskFlowReturn1">
      <outcome>
        <name>back</name>
      </outcome>
    </task-flow-return>
    <control-flow-rule id="__1">
      <from-activity-id>site</from-activity-id>
      <control-flow-case id="__2">
        <from-outcome>back</from-outcome>
        <to-activity-id>taskFlowReturn1</to-activity-id>
      </control-flow-case>
    </control-flow-rule>
    <use-page-fragments/>
  </task-flow-definition>
</adfc-config>
